# CENTURION — Environment Variables
# Copy this file and fill in your API keys.
# These should be set in your shell profile (~/.bashrc or ~/.zshrc).

# Brave Search API (for EXPLORATOR web search)
# Get key at: https://brave.com/search/api/
export BRAVE_API_KEY="your_brave_api_key_here"

# GitHub Personal Access Token (for GitHub MCP server)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
export GITHUB_PERSONAL_ACCESS_TOKEN="github_pat_your_token_here"

# Perplexity API (for EXPLORATOR deep search)
# Get key at: https://docs.perplexity.ai/
export PERPLEXITY_API_KEY="pplx-your_key_here"

# GitHub MCP Server binary (optional, auto-installed by install.sh)
# export GITHUB_MCP_SERVER_PATH="$HOME/.local/bin/github-mcp-server"
